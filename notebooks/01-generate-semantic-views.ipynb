# O código abaixo mostra um trecho do código usado para geração de documentos cujo tipo_evidencia são MunicipioCriticoIncidencia. Logo abaixo 
# é impresso 3 documentos com metadados e texto para facilitar a resposta do LLM.

from datetime import datetime
import json

# Descobrir semana epidemiológica final
semana_final = 22  # substitua por cálculo automático se já tiver a coluna

documentos = []

for _, row in municipios_criticos.iterrows():

    doc = {
        "id": f"municipio_critico_{row['ID_MN_RESI']}",
        "metadata": {
            "tipo_evidencia": "MunicipioCriticoIncidencia",
            "ano": 2026,
            "semana_inicial": 1,
            "semana_final": semana_final,
            "municipio": row["Nome_Municipio"],
            "uf": row["UF"],
            "total_casos": int(row["total_casos"]),
            "populacao": int(row["Populacao"]),
            "incidencia_100k": round(float(row["incidencia_100k"]), 2),
            "criterio": "incidencia_maior_300",
            "data_geracao": datetime.now().strftime("%Y-%m-%d")
        },
        "text": (
            f"O município de {row['Nome_Municipio']} ({row['UF']}) "
            f"registrou {int(row['total_casos'])} casos prováveis de dengue "
            f"entre as semanas epidemiológicas 1 e {semana_final} de 2026. "
            f"A população considerada foi de {int(row['Populacao'])} habitantes. "
            f"A incidência observada foi de "
            f"{float(row['incidencia_100k']):.1f} casos por 100 mil habitantes. "
            f"Segundo o critério epidemiológico adotado, o município apresenta "
            f"situação de incidência elevada."
        )
    }

    documentos.append(doc)

# Mostrar os 3 primeiros documentos
for i, doc in enumerate(documentos[:3], start=1):
    print("=" * 100)
    print(f"DOCUMENTO {i}")
    print("=" * 100)
    print(json.dumps(doc, indent=2, ensure_ascii=False))
    print()

